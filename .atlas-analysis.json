  "keyFeatures": [
    "Multi-protocol data source support (Modbus, BACnet, SNMP, SQL, HTTP, MQTT, and more)",
    "Real-time graphical views with drag-and-drop interface builder",
    "Alarm and event management with email/SMS notifications",
    "Historical data logging and reporting",
    "Watch lists for monitoring multiple data points",
    "Synoptic panel for custom SCADA visualizations",
    "Point hierarchy for organizing data points",
    "REST API for integration and automation",
    "Docker-based deployment with MySQL backend",
    "Role-based access control with user profiles"
  ],
  "publicApiSurface": [
    "GET /api/auth/{username}/{password}",
    "GET /api/auth/logout/{username}",
    "GET /api/datapoint",
    "GET /api/datapoints",
    "GET /api/datasource",
    "GET /api/datasource/getAll",
    "GET /api/pointvalue/getValue/{xid}",
    "PUT /api/pointvalue/setValue/{xid}",
    "GET /api/events/datapoint/{id}",
